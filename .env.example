# Discord Configuration
DISCORD_TOKEN="your_discord_bot_token"
BOT_ACTIVITY_TYPE="watching"  # watching, playing, listening, streaming
BOT_ACTIVITY_TEXT="conversations unfold"

# LLM Configuration
MAIN_LLM_MODEL="gemini/gemini-2.5-flash"
DECISION_LLM_MODEL="gemini/gemini-2.5-flash-lite"  # Lightweight model for reply decisions

# Prompt Configuration
BEHAVIOR_PROMPT="You are a helpful Discord bot assistant."
CAPABILITIES_PROMPT="This is your *CAPABILITIES_PROMPT*, IT IS VERY IMPORTANT, FOLLOW THIS EXACTLY: You are a Discord bot with the following capabilities: You can reply to messages, react with emojis, mention users using <@UserID>, process images/videos/audio/documents when supported by your model, and access web search when available."

# API Keys (add as needed for different providers)
GEMINI_API_KEY="your_gemini_key"
OPENAI_API_KEY="your_openai_key"
ANTHROPIC_API_KEY="your_anthropic_key"

# Rate Limiting (in seconds between requests)
MAIN_LLM_RATE_LIMIT_ENABLED=False
MAIN_LLM_RATE_LIMIT_SECONDS=2
DECISION_LLM_RATE_LIMIT_ENABLED=False
DECISION_LLM_RATE_LIMIT_SECONDS=0.5

# Web Search Configuration
WEB_SEARCH_ENABLED=True  # Enable/disable web search functionality
WEB_SEARCH_CONTEXT_SIZE="medium"  # low, medium, high - controls search result context size

# Backup Configuration
BACKUP_INTERVAL_HOURS=24

# Summary and Profile Update Triggers (these can be overridden per server/channel via commands)
# These are fallback defaults when not configured via /set_llm command
DEFAULT_SUMMARIZE_EVERY_MESSAGES=100
DEFAULT_SUMMARIZE_EVERY_HOURS=24
DEFAULT_PROFILE_UPDATE_EVERY_MESSAGES=50
DEFAULT_PROFILE_UPDATE_EVERY_HOURS=168 # 1 week

# Media Processing Default Settings (can be overridden via /media_config commands)
# These are fallback defaults when not configured via admin commands
DEFAULT_MEDIA_IMAGES_ENABLED=True
DEFAULT_MEDIA_AUDIO_ENABLED=True
DEFAULT_MEDIA_VIDEO_ENABLED=True
DEFAULT_MEDIA_PDF_ENABLED=True
DEFAULT_MEDIA_OFFICE_DOCUMENTS_ENABLED=True
DEFAULT_MEDIA_TEXT_FILES_ENABLED=True
DEFAULT_MEDIA_OTHER_FILES_ENABLED=True
