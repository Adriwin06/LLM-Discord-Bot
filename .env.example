# Discord Configuration
DISCORD_TOKEN="your_discord_bot_token"
BOT_ACTIVITY_TYPE="watching"  # watching, playing, listening, streaming
BOT_ACTIVITY_TEXT="conversations unfold"

# Logging Configuration
LOG_LEVEL=DEBUG              # Root logger level
LOG_CONSOLE_LEVEL=INFO       # Terminal output level
LOG_FILE_LEVEL=DEBUG         # logs/bot.log detail level
LOG_DIR="logs"
LOG_FILE="bot.log"
LOG_MAX_BYTES=10485760       # 10 MB per log file
LOG_BACKUP_COUNT=5           # Keep bot.log plus 5 rotated backups

# LLM Configuration
MAIN_LLM_MODEL="gemini/gemini-2.5-flash"
DECISION_LLM_MODEL="gemini/gemini-2.5-flash-lite"  # Lightweight model for reply decisions
DECISION_LLM_ENABLED=True  # False disables ambient decisions; bot replies only to direct mentions/replies

# API Keys (add as needed for different providers)
GEMINI_API_KEY="your_gemini_key"
OPENAI_API_KEY="your_openai_key"
ANTHROPIC_API_KEY="your_anthropic_key"
MISTRAL_API_KEY="your_mistral_key"

# Rate Limiting (in seconds between requests)
MAIN_LLM_RATE_LIMIT_ENABLED=False
MAIN_LLM_RATE_LIMIT_SECONDS=2
DECISION_LLM_RATE_LIMIT_ENABLED=False
DECISION_LLM_RATE_LIMIT_SECONDS=0.5
REPLY_CHAIN_DEBOUNCE_ENABLED=True
REPLY_CHAIN_DEBOUNCE_SECONDS=2.0  # Wait this long for same-user message fragments before deciding
REPLY_CHAIN_WAIT_FOR_TYPING=True
REPLY_CHAIN_TYPING_MAX_WAIT_SECONDS=12.0
REPLY_CHAIN_LONG_TYPING_SECONDS=10.0
TYPING_ACTIVE_SECONDS=8.0  # Discord sends typing-start pulses, not typing-stop events
GIFS_ENABLED=True

# Web Search Configuration
WEB_SEARCH_ENABLED=True  # Enable/disable explicit web_search and fetch_web_page tools
WEB_SEARCH_AUTO_ENABLED=False  # If true, provider-side web search may be attached to ordinary replies automatically
WEB_SEARCH_CONTEXT_SIZE="medium"  # low, medium, high - controls search result context size
WEB_FETCH_MAX_CHARS=6000  # Maximum extracted text returned by fetch_web_page

# Agentic Tool Configuration
TOOLS_ENABLED=True       # Enables read-only Discord tool calls for the main response model
TOOL_MAX_ROUNDS=0        # 0 = unlimited; otherwise maximum tool-call rounds before forcing a final answer

# Backup Configuration
BACKUP_INTERVAL_HOURS=24

# Summary and Profile Update Triggers (these can be overridden per server/channel via commands)
# These are fallback defaults when not configured via /set_llm command
DEFAULT_SUMMARIZE_EVERY_MESSAGES=100
INITIAL_SUMMARY_MESSAGES=1000
DEFAULT_SUMMARIZE_EVERY_HOURS=24
DEFAULT_PROFILE_UPDATE_EVERY_MESSAGES=50
DEFAULT_PROFILE_UPDATE_EVERY_HOURS=168 # 1 week

# Media Processing Default Settings (can be overridden via /media_config commands)
# These are fallback defaults when not configured via admin commands
DEFAULT_MEDIA_IMAGES_ENABLED=True
DEFAULT_MEDIA_AUDIO_ENABLED=True
DEFAULT_MEDIA_VIDEO_ENABLED=True
DEFAULT_MEDIA_PDF_ENABLED=True
DEFAULT_MEDIA_OFFICE_DOCUMENTS_ENABLED=True
DEFAULT_MEDIA_TEXT_FILES_ENABLED=True
DEFAULT_MEDIA_OTHER_FILES_ENABLED=True

# GIF Processing Configuration
DEFAULT_GIF_MAX_FRAMES=8           # Maximum number of frames to extract from animated GIFs
DEFAULT_GIF_FRAME_QUALITY=85       # JPEG quality for extracted frames (1-100, higher = better quality)

# Local Speech-to-Text Configuration (faster-whisper; no API key required)
LOCAL_STT_ENGINE="faster-whisper"  # faster-whisper, or whisper for the legacy local fallback if installed
LOCAL_STT_MODEL="base"             # tiny, base, small, medium, large-v3, turbo, or a local CTranslate2 model path
LOCAL_STT_DEVICE="cpu"             # cpu or cuda
LOCAL_STT_COMPUTE_TYPE="int8"      # int8 is a practical CPU default; use float16 on CUDA
LOCAL_STT_BEAM_SIZE=5
LOCAL_STT_VAD_FILTER=True
# LOCAL_STT_LANGUAGE="en"          # Optional fixed language; leave unset for auto-detection

# Video Processing Configuration
DEFAULT_VIDEO_MAX_SIZE_MB=250
DEFAULT_MEDIA_PROBE_TIMEOUT_SECONDS=10
DEFAULT_VIDEO_FRAME_TIMEOUT_SECONDS=20
DEFAULT_VIDEO_MAX_FRAMES=8
DEFAULT_VIDEO_FRAME_QUALITY=85
